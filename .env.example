# Copy this file to .env.local and replace with your project values.
# Supabase: Dashboard → Project Settings → API
#   - Project URL (https://xxxx.supabase.co) → VITE_SUPABASE_URL — not the dashboard browser URL
#   - anon public key → VITE_SUPABASE_ANON_KEY
# Restart `npm run dev` after changing env vars.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: when set to 1 or true, students with a class + resolvable unit are redirected from legacy
# flat mode routes (/practice, /learn, …) to /class/:classId/unit/:unitId/:mode. Default: off.
# VITE_CURRICULUM_V2=1
